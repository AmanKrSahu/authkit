# General
PORT=8000
NODE_ENV=development
BASE_PATH="/api/v1"
DOMAIN_URL="localhost"

# Frontend Origins (comma-separated)
FRONTEND_ORIGINS="http://localhost:3000"

# PostgreSQL Database
POSTGRES_USER="your_username"
POSTGRES_PASSWORD="your_password"
POSTGRES_DB="authkit"
DATABASE_URL="postgresql://your_username:your_password@postgres:5432/authkit?schema=public"

# Redis
REDIS_HOST="localhost"
REDIS_PORT=6379

# Google OAuth
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_CALLBACK_URL="http://localhost:8000/api/v1/oauth/google/callback"

# Security Tokens & Secrets
# -------------------------
# Run `pnpm generate:secrets` to generate all these values securely.
# They will be output to `generated-secrets.json`, from where you can copy them here.

# JWT Authentication
JWT_SECRET=""
JWT_REFRESH_SECRET=""
JWT_RESET_SECRET=""
JWT_MFA_LOGIN_SECRET=""

# Resend Email Service
RESEND_API_KEY="your-resend-api"
RESEND_SENDER_EMAIL="noreply@yourdomain.com"

# Authenticator App Secret
AUTHENTICATOR_APP_SECRET=""

# OIDC Configuration (Comma-separated list for cookie encryption)
OIDC_COOKIE_KEYS=""

# JSON Web Key Set (JWKS) for signing tokens (MUST be a valid JSON string)
OIDC_JWKS=''
